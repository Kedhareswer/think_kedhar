# LLM backend is Claude Code CLI (`claude` on PATH). No API key required.
# Override model if you want a non-default Claude variant.
LLM_MODEL=claude-opus-4-7
# Thinking effort passed as `--effort <level>` to the Claude CLI.
# Allowed: "low" | "medium" | "high" | "max" | "" (omit the flag entirely).
# Replaces the older MEDBRAIN_THINKING_HINT env (magic-phrase prepend) which
# is no longer honored — the CLI flag is more reliable.
MEDBRAIN_EFFORT=max

PUBMED_API_KEY=
PUBMED_EMAIL=you@example.com

BRAIN_DIR=./brain
LOG_LEVEL=INFO
