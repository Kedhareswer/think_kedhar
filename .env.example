# LLM backend is Claude Code CLI (`claude` on PATH). No API key required.
# Override model if you want a non-default Claude variant.
LLM_MODEL=claude-opus-4-7
# Thinking budget hint injected into every user prompt.
# Allowed: "" (off), "think", "think hard", "think harder", "ultrathink".
MEDBRAIN_THINKING_HINT=ultrathink

PUBMED_API_KEY=
PUBMED_EMAIL=you@example.com

BRAIN_DIR=./brain
LOG_LEVEL=INFO
